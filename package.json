{
  "name": "jules-pr-reviewer",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action that uses Google Jules to review pull requests and post review comments.",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "commit": "git add . && cz"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thalesraymond/jules-pr-reviewer.git"
  },
  "author": "thalesraymond",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/thalesraymond/jules-pr-reviewer/issues"
  },
  "homepage": "https://github.com/thalesraymond/jules-pr-reviewer#readme",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@google/jules-sdk": "^0.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@vercel/ncc": "^0.38.4",
    "@vitest/coverage-v8": "^4.1.8",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
